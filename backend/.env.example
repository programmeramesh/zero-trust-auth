# Backend environment example - DO NOT COMMIT SECRETS

# App
MONGO_URI=mongodb://127.0.0.1:27017/yourDB
JWT_SECRET=your_jwt_secret
PORT=5000
FRONTEND_URL=http://localhost:5173

# AWS (S3) - required for file upload/download operations
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# HuggingFace API key (used by AI summarizer/chat features)
# You can set either of these names; code accepts both.
HUGGINGFACE_API_KEY=hf_xxx
HF_API_KEY=hf_xxx

# SMTP (optional - for email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
FROM_EMAIL="Secure Vault <no-reply@example.com>"
